type User {
    id: ID!
    username: String
    email: String
    currency: String
}

type Transaction {
    id: ID!
    amount: Float!
    type: String!
    tags: String
    notes: String
    timestamp: String
    userId: ID
}

type BalanceDTO {
    totalIncome: Float!
    totalExpense: Float!
    balance: Float!
}

type Group {
    id: ID!
    name: String!
    ownerId: ID
}

type Membership {
    id: ID!
    userId: ID!
    groupId: ID!
    userEmail: String
}

type Debt {
    id: ID!
    debtorId: ID!
    creditorId: ID!
    groupId: ID!
    amount: Float!
    title: String
    paidByDebtor: Boolean!
    confirmedByCreditor: Boolean!
    debtor: User
    creditor: User
}

input TransactionInput {
    amount: Float!
    type: String!
    tags: String
    notes: String
}

input GroupInput {
    name: String!
}

input MembershipInput {
    userEmail: String!
    groupId: ID!
}

input DebtInput {
    debtorId: ID!
    creditorId: ID!
    groupId: ID!
    amount: Float!
    title: String!
}

input GroupTransactionInput {
    groupId: ID!
    amount: Float!
    type: String!
    title: String!
    selectedUserIds: [ID!]
}

type Query {
    transactions(
        type: String,
        tag: String,
        minAmount: Float,
        maxAmount: Float,
        sortBy: String,
        sortDirection: String
    ): [Transaction!]!

    userBalance(days: Int): BalanceDTO!

    groups: [Group!]!
    myGroups: [Group!]!
    groupMembers(groupId: ID!): [Membership!]!
    groupDebts(groupId: ID!): [Debt!]!
}

type Mutation {
    addTransaction(transactionDTO: TransactionInput!): Transaction!
    updateTransaction(id: ID!, transactionDTO: TransactionInput!): Transaction!
    deleteTransaction(id: ID!): Boolean!

    createGroup(groupDTO: GroupInput!): Group!
    deleteGroup(id: ID!): Boolean!

    addMember(membershipDTO: MembershipInput!): Membership!
    removeMember(membershipId: ID!): Boolean!

    createDebt(debtDTO: DebtInput!): Debt!
    deleteDebt(debtId: ID!): Boolean!
    markDebtAsPaid(debtId: ID!): Debt!
    confirmDebtPayment(debtId: ID!): Debt!

    addGroupTransaction(groupTransactionDTO: GroupTransactionInput!): Boolean!
}